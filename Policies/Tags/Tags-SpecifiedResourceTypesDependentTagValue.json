{
  "name": "Tags-SpecifiedResourceTypesDependentTagValue",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Require a tag on specified resource types when a dependent tag has a specific value",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Enforces existence of a tag on specified resource types when a dependent tag has a specific value. Does not apply to resource groups.",
    "metadata": {
      "category": "Tags",
      "version": "1.0.0"
    },
    "parameters": {
      "tagName": {
        "type": "String",
        "metadata": {
          "displayName": "Tag Name",
          "description": "Name of the tag, such as 'environment'"
        }
      },
      "resourceTypes": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Types",
          "description": "Resource types to apply tag to (eg. Microsoft.Compute/virtualMachine)"
        }
      },
      "dependentTagName": {
        "type": "String",
        "metadata": {
          "displayName": "Dependent Tag Name",
          "description": "Name of the dependent tag, such as 'environment'"
        }
      },
      "dependentTagValue": {
        "type": "String",
        "metadata": {
          "displayName": "Dependent Tag Value",
          "description": "Value of the dependent tag, such as 'production'"
        }
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "in": "[parameters('resourceTypes')]"
          },
          {
            "field": "[concat('tags[', parameters('tagName'), ']')]",
            "exists": "false"
          },
          {
            "field": "[concat('tags[', parameters('dependentTagName'), ']')]",
            "equals": "[parameters('dependentTagValue')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}