{
  "name": "Enforce-Tags",
  "type": "Microsoft.Authorization/policySetDefinitions",
  "scope": null,
  "properties": {
    "displayName": "Required Tags",
    "policyType": "Custom",
    "description": "Enforce required tags on resources and resource groups to ensure proper governance, management, and cost tracking. This initiative includes policies that require specific tags such as DataClassification, OpCo, ResourceOwner, LastTagReview, BUID, SNApplicationServiceID, InternetFacing, ExternalFQDN, and MachineName. By implementing these policies, organizations can enhance resource organization, improve security and compliance, and facilitate efficient resource management across their Azure environment.",
    "metadata": {
      "category": "Tags",
      "version": "1.0.0"
    },
    "parameters": {
      "EnvironmentAllowedValues": {
        "type": "Array"
      },
      "EnvironmentTagEffect": {
        "type": "String",
        "allowedValues": [
          "Deny",
          "Audit"
        ],
        "defaultValue": "Audit"
      },
      "SegmentAllowedValues": {
        "type": "Array"
      },
      "SegmentTagEffect": {
        "type": "String",
        "allowedValues": [
          "Deny",
          "Audit"
        ],
        "defaultValue": "Audit"
