        "allowedValues": [
          "Deny",
          "Audit"
        ],
        "defaultValue": "Audit"
      },
      "LastTagReviewTagEffect": {
        "type": "String",
        "allowedValues": [
          "Deny",
          "Audit"
        ],
        "defaultValue": "Audit"
      },
      "SNowInstanceIDResourceTypes": {
        "type": "Array"
      },
      "SNowInstanceIDTagEffect": {
        "type": "String",
        "allowedValues": [
          "Deny",
          "Audit"
        ],
        "defaultValue": "Audit"
